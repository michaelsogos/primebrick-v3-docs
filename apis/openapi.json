{
  "openapi": "3.0.0",
  "info": {
    "title": "Primebrick API",
    "version": "1.0.0",
    "description": "Primebrick aggregated API specification. This placeholder is replaced by the real aggregated spec from the backend during the build command."
  },
  "servers": [
    { "url": "http://localhost:3001", "description": "Local development" }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "summary": "Health check",
        "description": "Returns the health status of the backend.",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
